{
  "meta": {
    "width": 296,
    "height": 152,
    "background": "white"
  },
  "elements": [
    {
      "type": "text",
      "x": 8,
      "y": 6,
      "content": "${city}",
      "size": 16,
      "fonts": ["source-han-bold", "unifont"]
    },
    {
      "type": "text",
      "x": 8,
      "y": 50,
      "content": "${temp}°",
      "size": 48,
      "fonts": ["source-han-bold", "unifont"]
    },
    {
      "type": "container",
      "layout": "vbox",
      "x": 140,
      "y": 50,
      "gap": 4,
      "children": [
        { "type": "text", "content": "天气: ${condition}", "size": 14 },
        { "type": "text", "content": "湿度: ${humidity}%", "size": 12 },
        { "type": "text", "content": "风力: ${wind}", "size": 12 }
      ]
    },
    { "type": "line", "x1": 0, "y1": 130, "x2": 296, "y2": 130, "width": 1 },
    { "type": "text", "x": 8, "y": 136, "content": "更新: ${updated}", "size": 10 }
  ]
}
